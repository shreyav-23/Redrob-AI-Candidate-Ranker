        "# ============================================\n",
        "# 4. Candidate Generator\n",
        "# ============================================\n",
        "\n",
        "def candidate_generator(path):\n",
        "\n",
        "\n",
        "    with open(path, \"r\", encoding=\"utf-8\") as file:\n",
        "\n",
        "        for line in file:\n",
        "\n",
        "            if line.strip():\n",
        "\n",
        "                yield json.loads(line)"
      ],
      "metadata": {
        "id": "8wnliUUvFuiR"
      },
      "execution_count": null,
      "outputs": []
